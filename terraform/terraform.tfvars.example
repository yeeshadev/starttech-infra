aws_region           = "us-east-1"
environment          = "production"
project_name         = "muchtodo"
ec2_instance_type    = "t3.micro"
ecr_repository_name  = "muchtodo-backend"
alert_email          = "your-email@example.com"
asg_min_size         = 1
asg_max_size         = 3
asg_desired_capacity = 1

# Sensitive values — set via TF_VAR_* environment variables or a .tfvars file NOT committed to git:
# mongo_uri      = "mongodb+srv://user:password@cluster.mongodb.net/much_todo_db"
# jwt_secret_key = "your-super-secret-key-at-least-32-characters"
# redis_password = ""
